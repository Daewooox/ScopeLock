{
  "name": "scopelock",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test && node --test benchmarks/coordination/*.test.mjs",
    "typecheck": "pnpm --filter @scopelock/core build && pnpm -r typecheck",
    "demo:flight-control": "pnpm build && node benchmarks/coordination/run-flight-control-demo.mjs",
    "demo:pilot": "pnpm build && node benchmarks/coordination/run-pilot-demo.mjs",
    "demo:wallet": "pnpm build && node benchmarks/coordination/run-wallet-demo.mjs",
    "benchmark:receipt": "pnpm build && node benchmarks/coordination/run-codex-real-agent-benchmark.mjs --runs 3 --modes scopelock_run --output-dir .scopelock/reports/receipt-baseline"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^7.0.2"
  }
}
