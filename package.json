{
  "name": "scopelock",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test && node --test benchmarks/coordination/*.test.mjs scripts/release/*.test.mjs scripts/demo-svg/*.test.mjs",
    "typecheck": "pnpm --filter @scopelock/core build && pnpm -r typecheck",
    "demo:flight-control": "pnpm build && node benchmarks/coordination/run-flight-control-demo.mjs",
    "demo:progressive": "pnpm build && node benchmarks/coordination/run-progressive-cli-demo.mjs",
    "demo:pilot": "pnpm build && node benchmarks/coordination/run-pilot-demo.mjs",
    "demo:wallet": "pnpm build && node benchmarks/coordination/run-wallet-demo.mjs",
    "demo:svg": "pnpm build && node scripts/demo-svg/generate.mjs",
    "demo:svg:check": "pnpm build && node scripts/demo-svg/generate.mjs --check",
    "benchmark:receipt": "pnpm build && node benchmarks/coordination/run-codex-real-agent-benchmark.mjs --runs 3 --modes scopelock_run --output-dir .scopelock/reports/receipt-baseline",
    "release:pack": "node scripts/release/pack.mjs",
    "release:smoke": "node scripts/release/smoke-packed.mjs",
    "release:audit": "node scripts/release/audit-packed.mjs",
    "release:evidence": "node scripts/release/generate-evidence.mjs",
    "release:rehearse": "pnpm release:pack && pnpm release:audit && node scripts/release/smoke-packed.mjs --out .release-artifacts/smoke-local.json && pnpm --filter @scopelock/core build && node scripts/release/generate-evidence.mjs --smoke-dir .release-artifacts --dependency-audit passed"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.8.0"
  }
}
