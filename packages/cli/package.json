{
  "name": "@scopelock/cli",
  "version": "0.1.0",
  "description": "Local guardrails for AI coding agents: approve a scope contract, export prompts, and enforce it with drift checks and editor hooks.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "scopelock": "./dist/index.js"
  },
  "files": [
    "dist/commands",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/run.d.ts",
    "dist/run.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Daewooox/ScopeLock.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json",
    "test": "node --test dist/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@scopelock/core": "workspace:^",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
