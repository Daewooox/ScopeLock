{
  "name": "@scopelock/mcp",
  "version": "0.1.0-beta.1",
  "description": "MCP stdio server for ScopeLock's narrow planning and drift-verification tools.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "scopelock-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.js",
    "dist/tools.d.ts",
    "dist/tools.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Daewooox/ScopeLock.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scopelock/core": "workspace:^",
    "zod": "^4.4.3"
  }
}
