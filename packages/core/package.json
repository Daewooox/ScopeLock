{
  "name": "@scopelock/core",
  "version": "0.1.0",
  "description": "Deterministic core for ScopeLock: contract/drift schemas, git-driven drift engine, and rule-based hook gate.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/agents",
    "dist/drift",
    "dist/format.d.ts",
    "dist/format.js",
    "dist/git",
    "dist/harness",
    "dist/hook",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/manifest",
    "dist/render",
    "dist/rules",
    "dist/schedule",
    "dist/schemas",
    "dist/storage"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Daewooox/ScopeLock.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "picomatch": "^4.0.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.3"
  }
}
