{
  "name": "@scopelock/core",
  "version": "0.1.0-beta.1",
  "description": "Deterministic core for ScopeLock: contract/drift schemas, git-driven drift engine, and rule-based hook gate.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Daewooox/ScopeLock.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Daewooox/ScopeLock#readme",
  "bugs": {
    "url": "https://github.com/Daewooox/ScopeLock/issues"
  },
  "keywords": [
    "ai-coding-agents",
    "scope-control",
    "drift-detection",
    "git",
    "zod"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "picomatch": "^4.0.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.3"
  }
}
